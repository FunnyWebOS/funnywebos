// ===================================================================
function drawColorWheel() {
  const canvas = document.getElementById('color-wheel-canvas');
  const c = canvas.getContext('2d');
  const w = canvas.width, h = canvas.height;
  const cx = w / 2, cy = h / 2, r = Math.min(w, h) / 2 - 2;
  for (let angle = 0; angle < 360; angle += 1) {
    const startAngle = (angle - 1) * Math.PI / 180;
    const endAngle = (angle + 1) * Math.PI / 180;
    const grad = c.createRadialGradient(cx, cy, 0, cx, cy, r);
    grad.addColorStop(0, 'white');
    grad.addColorStop(1, `hsl(${angle}, 100%, 50%)`);
    c.beginPath();
    c.moveTo(cx, cy);
    c.arc(cx, cy, r, startAngle, endAngle);
    c.closePath();
    c.fillStyle = grad;
    c.fill();
  }
  // Dark center radial for brightness
  const darkGrad = c.createRadialGradient(cx, cy, 0, cx, cy, r);
  darkGrad.addColorStop(0.5, 'transparent');
  darkGrad.addColorStop(1, 'black');
  c.beginPath(); c.arc(cx, cy, r, 0, Math.PI * 2);
  c.fillStyle = darkGrad; c.fill();

  canvas.onclick = (e) => {
    const rect = canvas.getBoundingClientRect();
    const x = (e.clientX - rect.left) * (w / rect.width);
    const y = (e.clientY - rect.top) * (h / rect.height);
    const pixel = c.getImageData(x, y, 1, 1).data;
    updateColorPanel(pixel[0], pixel[1], pixel[2]);
  };
}

