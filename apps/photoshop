function applyFilter(type) {
  currentFilter = type;
  const titles = { blur:'Flou gaussien', sharpen:'Accentuation', noise:'Bruit', emboss:'Emboss', edge:'Contours', sepia:'Sépia', grayscale:'Niveaux de gris', vintage:'Vintage', vignette:'Vignette', pixelate:'Pixelisation', cartoon:'Cartoon' };
  document.getElementById('filter-modal-title').textContent = titles[type] || type;

  const content = document.getElementById('filter-modal-content');
  if (type === 'blur') {
    content.innerHTML = `<div class="modal-row"><span class="modal-label">Rayon:</span><input type="range" class="modal-input" id="filter-radius" min="1" max="20" value="3" style="padding:0"><span id="filter-r-val">3</span> px</div>`;
    document.getElementById('filter-radius').oninput = (e) => document.getElementById('filter-r-val').textContent = e.target.value;
  } else if (type === 'noise') {
    content.innerHTML = `<div class="modal-row"><span class="modal-label">Intensité:</span><input type="range" class="modal-input" id="filter-noise" min="1" max="100" value="20" style="padding:0"><span id="filter-n-val">20</span></div>`;
    document.getElementById('filter-noise').oninput = (e) => document.getElementById('filter-n-val').textContent = e.target.value;
  } else if (type === 'pixelate') {
    content.innerHTML = `<div class="modal-row"><span class="modal-label">Taille:</span><input type="range" class="modal-input" id="filter-pix" min="2" max="50" value="8" style="padding:0"><span id="filter-p-val">8</span> px</div>`;
    document.getElementById('filter-pix').oninput = (e) => document.getElementById('filter-p-val').textContent = e.target.value;
  } else {
    content.innerHTML = '<p style="color:var(--text-dim);font-size:11px;padding:4px 0;">Aucun paramètre pour ce filtre.</p>';
  }

  // Preview
  const lctx = getActiveLayerCtx();
  const previewCanvas = document.getElementById('filter-preview-canvas');
  const pc = previewCanvas.getContext('2d');
  pc.drawImage(layers[activeLayerIndex].canvas, 0, 0, 196, 120);

  openModal('modal-filter');
}

function applyFilterConfirm() {
  const lctx = getActiveLayerCtx();
  const w = mainCanvas.width, h = mainCanvas.height;
  const imgData = lctx.getImageData(0, 0, w, h);
  const d = imgData.data;

  switch (currentFilter) {
    case 'grayscale':
      for (let i = 0; i < d.length; i += 4) {
        const g = 0.299*d[i]+0.587*d[i+1]+0.114*d[i+2];
        d[i] = d[i+1] = d[i+2] = g;
      }
      break;
    case 'sepia':
      for (let i = 0; i < d.length; i += 4) {
        const r = d[i], g = d[i+1], b = d[i+2];
        d[i] = Math.min(255, r*0.393+g*0.769+b*0.189);
        d[i+1] = Math.min(255, r*0.349+g*0.686+b*0.168);
        d[i+2] = Math.min(255, r*0.272+g*0.534+b*0.131);
      }
      break;
    case 'invert':
      for (let i = 0; i < d.length; i += 4) {
        d[i] = 255-d[i]; d[i+1] = 255-d[i+1]; d[i+2] = 255-d[i+2];
      }
      break;
    case 'noise':
      const noiseAmt = parseInt(document.getElementById('filter-noise')?.value || 20);
      for (let i = 0; i < d.length; i += 4) {
        const n = (Math.random() - 0.5) * noiseAmt * 2;
        d[i] = Math.max(0,Math.min(255,d[i]+n));
        d[i+1] = Math.max(0,Math.min(255,d[i+1]+n));
        d[i+2] = Math.max(0,Math.min(255,d[i+2]+n));
      }
      break;
    case 'sharpen':
      applyConvolution(d, w, h, [0,-1,0,-1,5,-1,0,-1,0]);
      break;
    case 'emboss':
      applyConvolution(d, w, h, [-2,-1,0,-1,1,1,0,1,2]);
      break;
    case 'edge':
      applyConvolution(d, w, h, [-1,-1,-1,-1,8,-1,-1,-1,-1]);
      break;
    case 'blur':
      const radius = parseInt(document.getElementById('filter-radius')?.value || 3);
      applyBoxBlur(d, w, h, radius);
      break;
    case 'vintage':
      for (let i = 0; i < d.length; i += 4) {
        d[i] = Math.min(255, d[i]*1.2); // boost red
        d[i+2] = Math.max(0, d[i+2]*0.8); // reduce blue
        const g = 0.299*d[i]+0.587*d[i+1]+0.114*d[i+2];
        d[i] = Math.min(255, d[i]*0.7 + g*0.3 + 30);
        d[i+1] = Math.min(255, d[i+1]*0.8 + g*0.2 + 20);
        d[i+2] = Math.min(255, d[i+2]*0.6 + g*0.4);
      }
      break;
    case 'vignette':
      const cx = w/2, cy = h/2, maxDist = Math.sqrt(cx*cx+cy*cy);
      for (let y = 0; y < h; y++) {
        for (let x = 0; x < w; x++) {
          const i = (y * w + x) * 4;
          const dist = Math.sqrt((x-cx)**2+(y-cy)**2);
          const factor = 1 - Math.pow(dist/maxDist, 1.5) * 0.8;
          d[i] *= factor; d[i+1] *= factor; d[i+2] *= factor;
        }
      }
      break;
    case 'pixelate':
      const pxSize = parseInt(document.getElementById('filter-pix')?.value || 8);
      for (let y = 0; y < h; y += pxSize) {
        for (let x = 0; x < w; x += pxSize) {
          const i = (y * w + x) * 4;
          const r = d[i], g = d[i+1], b = d[i+2];
          for (let py = 0; py < pxSize && y+py < h; py++) {
            for (let px = 0; px < pxSize && x+px < w; px++) {
              const j = ((y+py)*w+(x+px))*4;
              d[j] = r; d[j+1] = g; d[j+2] = b;
            }
          }
        }
      }
      break;
    case 'cartoon':
      // Simplify colors
      for (let i = 0; i < d.length; i += 4) {
        d[i] = Math.round(d[i]/64)*64;
        d[i+1] = Math.round(d[i+1]/64)*64;
        d[i+2] = Math.round(d[i+2]/64)*64;
      }
      break;
  }

  lctx.putImageData(imgData, 0, 0);
  renderAllLayers();
  saveHistory('Filtre: ' + currentFilter);
  closeModal('modal-filter');
  updateLayerThumbs();
}

function applyConvolution(d, w, h, kernel) {
  const copy = new Uint8ClampedArray(d);
  const kSize = 3, half = 1;
  for (let y = 1; y < h-1; y++) {
    for (let x = 1; x < w-1; x++) {
      const idx = (y * w + x) * 4;
      for (let c = 0; c < 3; c++) {
        let sum = 0;
        for (let ky = -half; ky <= half; ky++) {
          for (let kx = -half; kx <= half; kx++) {
            const ki = (ky + half) * kSize + (kx + half);
            const pi = ((y+ky)*w+(x+kx))*4;
            sum += copy[pi+c] * kernel[ki];
          }
        }
        d[idx+c] = Math.max(0, Math.min(255, sum));
      }
    }
  }
}

function applyBoxBlur(d, w, h, radius) {
  const copy = new Uint8ClampedArray(d);
  const size = radius * 2 + 1;
  for (let y = radius; y < h - radius; y++) {
    for (let x = radius; x < w - radius; x++) {
      const idx = (y * w + x) * 4;
      for (let c = 0; c < 3; c++) {
        let sum = 0, count = 0;
        for (let dy = -radius; dy <= radius; dy++) {
          for (let dx = -radius; dx <= radius; dx++) {
            sum += copy[((y+dy)*w+(x+dx))*4+c];
            count++;
          }
        }
        d[idx+c] = sum / count;
      }
    }
  }
}

