<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PhotoEditor Pro</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; user-select: none; }

  :root {
    --bg-dark: #1a1a1a;
    --bg-panel: #252525;
    --bg-panel2: #2d2d2d;
    --bg-item: #333;
    --bg-hover: #3a3a3a;
    --bg-active: #4a90d9;
    --border: #404040;
    --text: #ccc;
    --text-dim: #888;
    --text-bright: #eee;
    --accent: #4a90d9;
    --accent2: #e07b39;
    --canvas-bg: #4a4a4a;
  }

  body {
    font-family: 'Inter', sans-serif;
    background: var(--bg-dark);
    color: var(--text);
    overflow: hidden;
    height: 100vh;
    display: flex;
    flex-direction: column;
    font-size: 12px;
  }

  /* ===== MENU BAR ===== */
  #menubar {
    background: var(--bg-panel);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    height: 30px;
    padding: 0 8px;
    flex-shrink: 0;
    z-index: 100;
  }

  .app-logo {
    color: var(--accent);
    font-weight: 700;
    font-size: 13px;
    margin-right: 16px;
    letter-spacing: 1px;
  }

  .menu-item {
    padding: 4px 10px;
    cursor: pointer;
    border-radius: 3px;
    transition: background 0.1s;
    position: relative;
  }
  .menu-item:hover { background: var(--bg-hover); }
  .menu-item:hover .dropdown { display: block; }

  .dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background: var(--bg-panel2);
    border: 1px solid var(--border);
    min-width: 180px;
    z-index: 1000;
    box-shadow: 0 4px 20px rgba(0,0,0,0.5);
    border-radius: 3px;
  }

  .dropdown-item {
    padding: 6px 16px;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .dropdown-item:hover { background: var(--bg-active); color: white; }
  .dropdown-sep { border-top: 1px solid var(--border); margin: 4px 0; }
  .shortcut { color: var(--text-dim); font-size: 11px; }
  .dropdown-item:hover .shortcut { color: rgba(255,255,255,0.7); }

  /* ===== TOOLBAR (OPTIONS BAR) ===== */
  #optionsbar {
    background: var(--bg-panel);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    height: 32px;
    padding: 0 8px;
    gap: 8px;
    flex-shrink: 0;
  }

  .opt-sep { width: 1px; height: 20px; background: var(--border); }

  .opt-btn {
    padding: 3px 8px;
    background: var(--bg-item);
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--text);
    cursor: pointer;
    font-size: 11px;
    transition: background 0.1s;
  }
  .opt-btn:hover { background: var(--bg-hover); }
  .opt-btn.active { background: var(--accent); border-color: var(--accent); color: white; }

  .opt-input {
    width: 50px;
    background: var(--bg-item);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 11px;
    text-align: center;
  }
  .opt-input:focus { outline: none; border-color: var(--accent); }

  .opt-label { color: var(--text-dim); font-size: 11px; }

  .opt-select {
    background: var(--bg-item);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 11px;
  }
  .opt-select:focus { outline: none; }

  /* ===== MAIN AREA ===== */
  #main {
    display: flex;
    flex: 1;
    overflow: hidden;
  }

  /* ===== LEFT TOOLS ===== */
  #tools {
    width: 46px;
    background: var(--bg-panel);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 4px 0;
    gap: 2px;
    overflow-y: auto;
    flex-shrink: 0;
  }

  .tool-btn {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border-radius: 4px;
    font-size: 18px;
    transition: background 0.1s;
    position: relative;
    title: attr(title);
  }
  .tool-btn:hover { background: var(--bg-hover); }
  .tool-btn.active { background: var(--accent); }

  .tool-sep { width: 28px; height: 1px; background: var(--border); margin: 4px 0; }

  /* Color swatches */
  #color-swatch {
    width: 36px;
    height: 36px;
    position: relative;
    margin-top: 4px;
  }
  #fg-color {
    width: 24px; height: 24px;
    position: absolute; top: 0; left: 0;
    border: 2px solid #888;
    cursor: pointer;
    border-radius: 2px;
  }
  #bg-color {
    width: 24px; height: 24px;
    position: absolute; bottom: 0; right: 0;
    border: 2px solid #888;
    cursor: pointer;
    border-radius: 2px;
  }
  #swap-colors {
    position: absolute; top: 0; right: 0;
    width: 14px; height: 14px;
    background: var(--bg-panel2);
    border: 1px solid var(--border);
    border-radius: 2px;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: 9px;
  }

  /* ===== CANVAS AREA ===== */
  #canvas-area {
    flex: 1;
    background: var(--canvas-bg);
    overflow: auto;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  #canvas-wrapper {
    position: relative;
    box-shadow: 0 0 40px rgba(0,0,0,0.7);
  }

  #main-canvas {
    display: block;
    cursor: crosshair;
  }

  /* Ruler */
  #ruler-h, #ruler-v {
    position: absolute;
    background: var(--bg-panel);
    border-bottom: 1px solid var(--border);
    font-size: 9px;
    color: var(--text-dim);
  }

  /* Zoom indicator */
  #zoom-indicator {
    position: absolute;
    bottom: 8px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0,0,0,0.6);
    color: var(--text);
    padding: 3px 10px;
    border-radius: 10px;
    font-size: 11px;
    pointer-events: none;
  }

  /* ===== RIGHT PANELS ===== */
  #right-panels {
    width: 230px;
    background: var(--bg-panel);
    border-left: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    flex-shrink: 0;
  }

  .panel {
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }

  .panel-header {
    padding: 6px 10px;
    background: var(--bg-panel2);
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    font-size: 11px;
    font-weight: 600;
    color: var(--text-bright);
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }
  .panel-header:hover { background: var(--bg-hover); }
  .panel-toggle { font-size: 10px; }

  .panel-body { padding: 8px; }
  .panel-body.collapsed { display: none; }

  /* ===== COLOR PANEL ===== */
  #color-wheel-canvas {
    width: 100%;
    border-radius: 50%;
    cursor: crosshair;
    display: block;
  }

  .color-sliders { margin-top: 8px; }

  .slider-row {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 5px;
  }

  .slider-label {
    width: 12px;
    font-size: 10px;
    color: var(--text-dim);
    font-weight: 600;
  }

  .slider-track {
    flex: 1;
    height: 12px;
    border-radius: 6px;
    cursor: pointer;
    position: relative;
    overflow: visible;
  }

  .slider-input {
    width: 100%;
    margin: 0;
    cursor: pointer;
    -webkit-appearance: none;
    height: 12px;
    border-radius: 6px;
    outline: none;
  }
  .slider-input::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 14px; height: 14px;
    border-radius: 50%;
    background: white;
    border: 2px solid #666;
    cursor: pointer;
  }

  .slider-val {
    width: 32px;
    background: var(--bg-item);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 1px 4px;
    border-radius: 2px;
    font-size: 10px;
    text-align: center;
  }
  .slider-val:focus { outline: none; border-color: var(--accent); }

  .hex-row {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 6px;
  }
  .hex-label { font-size: 10px; color: var(--text-dim); }
  .hex-input {
    flex: 1;
    background: var(--bg-item);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 3px 6px;
    border-radius: 3px;
    font-size: 11px;
    font-family: monospace;
  }
  .hex-input:focus { outline: none; border-color: var(--accent); }

  .color-preview {
    width: 100%;
    height: 20px;
    border-radius: 3px;
    border: 1px solid var(--border);
    margin-top: 6px;
  }

  /* ===== LAYERS PANEL ===== */
  #layers-list {
    max-height: 200px;
    overflow-y: auto;
  }

  .layer-item {
    display: flex;
    align-items: center;
    padding: 4px 6px;
    gap: 6px;
    border-radius: 3px;
    cursor: pointer;
    margin-bottom: 2px;
    border: 1px solid transparent;
  }
  .layer-item:hover { background: var(--bg-hover); }
  .layer-item.active { background: var(--bg-active); border-color: var(--accent); }

  .layer-vis {
    width: 16px;
    height: 16px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
  }

  .layer-thumb {
    width: 32px;
    height: 24px;
    border: 1px solid var(--border);
    border-radius: 2px;
    flex-shrink: 0;
    background: #fff;
  }

  .layer-name {
    flex: 1;
    font-size: 11px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .layer-lock { font-size: 10px; cursor: pointer; color: var(--text-dim); }

  .layers-toolbar {
    display: flex;
    gap: 4px;
    margin-top: 6px;
    padding-top: 6px;
    border-top: 1px solid var(--border);
  }

  .layers-tb-btn {
    flex: 1;
    padding: 4px;
    background: var(--bg-item);
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--text);
    cursor: pointer;
    font-size: 13px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.1s;
  }
  .layers-tb-btn:hover { background: var(--bg-hover); }

  /* Blend mode + opacity */
  .layer-opts {
    display: flex;
    gap: 6px;
    margin-bottom: 6px;
    align-items: center;
  }
  .layer-blend {
    flex: 1;
    background: var(--bg-item);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 3px 4px;
    border-radius: 3px;
    font-size: 11px;
  }
  .layer-opacity-label { font-size: 10px; color: var(--text-dim); white-space: nowrap; }
  .layer-opacity {
    width: 50px;
    background: var(--bg-item);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 3px 4px;
    border-radius: 3px;
    font-size: 11px;
    text-align: center;
  }

  /* ===== ADJUSTMENTS / PROPERTIES PANEL ===== */
  .adj-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
  }

  .adj-btn {
    padding: 5px;
    background: var(--bg-item);
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--text);
    cursor: pointer;
    font-size: 10px;
    text-align: center;
    transition: background 0.1s;
  }
  .adj-btn:hover { background: var(--accent); color: white; border-color: var(--accent); }

  /* ===== HISTORY PANEL ===== */
  #history-list {
    max-height: 120px;
    overflow-y: auto;
  }

  .history-item {
    padding: 4px 8px;
    cursor: pointer;
    border-radius: 3px;
    font-size: 11px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .history-item:hover { background: var(--bg-hover); }
  .history-item.current { color: var(--accent); font-weight: 500; }
  .history-icon { font-size: 12px; }

  /* ===== STATUS BAR ===== */
  #statusbar {
    height: 22px;
    background: var(--bg-panel);
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    padding: 0 12px;
    gap: 20px;
    font-size: 10px;
    color: var(--text-dim);
    flex-shrink: 0;
  }

  /* ===== MODALS ===== */
  .modal-overlay {
    display: none;
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0,0,0,0.7);
    z-index: 9000;
    align-items: center;
    justify-content: center;
  }
  .modal-overlay.open { display: flex; }

  .modal {
    background: var(--bg-panel2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 20px;
    min-width: 340px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.8);
  }

  .modal h3 {
    font-size: 14px;
    margin-bottom: 16px;
    color: var(--text-bright);
    border-bottom: 1px solid var(--border);
    padding-bottom: 10px;
  }

  .modal-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }

  .modal-label {
    width: 90px;
    font-size: 11px;
    color: var(--text-dim);
    text-align: right;
  }

  .modal-input {
    flex: 1;
    background: var(--bg-item);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 5px 8px;
    border-radius: 3px;
    font-size: 12px;
  }
  .modal-input:focus { outline: none; border-color: var(--accent); }

  .modal-btns {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
    margin-top: 16px;
  }

  .btn-primary {
    padding: 6px 16px;
    background: var(--accent);
    border: none;
    border-radius: 3px;
    color: white;
    cursor: pointer;
    font-size: 12px;
    transition: background 0.1s;
  }
  .btn-primary:hover { background: #3a80c9; }

  .btn-secondary {
    padding: 6px 16px;
    background: var(--bg-item);
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--text);
    cursor: pointer;
    font-size: 12px;
  }
  .btn-secondary:hover { background: var(--bg-hover); }

  /* ===== FILTERS MODAL ===== */
  .filter-preview {
    width: 100%;
    height: 120px;
    border: 1px solid var(--border);
    border-radius: 3px;
    margin-bottom: 12px;
    background: #333;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* ===== TEXT TOOL ===== */
  #text-overlay {
    position: absolute;
    display: none;
    z-index: 50;
  }

  #text-input {
    background: transparent;
    border: 1px dashed rgba(74,144,217,0.8);
    color: transparent;
    caret-color: var(--accent);
    outline: none;
    resize: none;
    min-width: 100px;
    min-height: 30px;
    font-family: sans-serif;
    padding: 4px;
    cursor: text;
  }

  /* Selection overlay */
  #selection-overlay {
    position: absolute;
    border: 1px dashed white;
    pointer-events: none;
    display: none;
    box-shadow: 0 0 0 1px rgba(0,0,0,0.5);
    animation: marchingAnts 0.5s linear infinite;
  }

  @keyframes marchingAnts {
    0% { stroke-dashoffset: 0; }
    100% { stroke-dashoffset: 20; }
  }

  /* Canvas info overlay */
  .canvas-info {
    position: absolute;
    top: 8px;
    right: 8px;
    background: rgba(0,0,0,0.5);
    color: rgba(255,255,255,0.6);
    padding: 3px 8px;
    border-radius: 3px;
    font-size: 10px;
    pointer-events: none;
  }

  /* ===== SCROLLBAR ===== */
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg-dark); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: #555; }

  /* tooltip */
  .tooltip {
    position: absolute;
    right: -120px;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(0,0,0,0.85);
    color: white;
    padding: 3px 8px;
    border-radius: 3px;
    white-space: nowrap;
    font-size: 11px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s;
    z-index: 200;
  }
  .tool-btn:hover .tooltip { opacity: 1; }
</style>
</head>
<body>

<!-- ===== MENU BAR ===== -->
<div id="menubar">
  <div class="app-logo">⬛ PS</div>

  <div class="menu-item">Fichier
    <div class="dropdown">
      <div class="dropdown-item" onclick="newDocument()">Nouveau... <span class="shortcut">Ctrl+N</span></div>
      <div class="dropdown-item" onclick="openFile()">Ouvrir... <span class="shortcut">Ctrl+O</span></div>
      <div class="dropdown-item" onclick="openRecent()">Ouvrir récent ▶</div>
      <div class="dropdown-sep"></div>
      <div class="dropdown-item" onclick="saveFile()">Enregistrer <span class="shortcut">Ctrl+S</span></div>
      <div class="dropdown-item" onclick="saveAs()">Enregistrer sous... <span class="shortcut">Ctrl+Shift+S</span></div>
      <div class="dropdown-item" onclick="exportPNG()">Exporter en PNG</div>
      <div class="dropdown-item" onclick="exportJPEG()">Exporter en JPEG</div>
      <div class="dropdown-sep"></div>
      <div class="dropdown-item" onclick="printDoc()">Imprimer <span class="shortcut">Ctrl+P</span></div>
      <div class="dropdown-sep"></div>
      <div class="dropdown-item">Quitter <span class="shortcut">Alt+F4</span></div>
    </div>
  </div>

  <div class="menu-item">Édition
    <div class="dropdown">
      <div class="dropdown-item" onclick="doUndo()">Annuler <span class="shortcut">Ctrl+Z</span></div>
      <div class="dropdown-item" onclick="doRedo()">Rétablir <span class="shortcut">Ctrl+Y</span></div>
      <div class="dropdown-sep"></div>
      <div class="dropdown-item" onclick="doCut()">Couper <span class="shortcut">Ctrl+X</span></div>
      <div class="dropdown-item" onclick="doCopy()">Copier <span class="shortcut">Ctrl+C</span></div>
      <div class="dropdown-item" onclick="doPaste()">Coller <span class="shortcut">Ctrl+V</span></div>
      <div class="dropdown-sep"></div>
      <div class="dropdown-item" onclick="selectAll()">Tout sélectionner <span class="shortcut">Ctrl+A</span></div>
      <div class="dropdown-item" onclick="deselect()">Désélectionner <span class="shortcut">Ctrl+D</span></div>
      <div class="dropdown-sep"></div>
      <div class="dropdown-item" onclick="fillFG()">Remplir avec couleur premier plan</div>
      <div class="dropdown-item" onclick="fillBG()">Remplir avec couleur arrière-plan</div>
      <div class="dropdown-item" onclick="clearArea()">Effacer</div>
    </div>
  </div>

  <div class="menu-item">Image
    <div class="dropdown">
      <div class="dropdown-item" onclick="showAdjModal('levels')">Niveaux... <span class="shortcut">Ctrl+L</span></div>
      <div class="dropdown-item" onclick="showAdjModal('curves')">Courbes... <span class="shortcut">Ctrl+M</span></div>
      <div class="dropdown-item" onclick="showAdjModal('hsl')">Teinte/Saturation... <span class="shortcut">Ctrl+U</span></div>
      <div class="dropdown-item" onclick="applyBrightness()">Luminosité/Contraste...</div>
      <div class="dropdown-item" onclick="desaturate()">Désaturer <span class="shortcut">Ctrl+Shift+U</span></div>
      <div class="dropdown-sep"></div>
      <div class="dropdown-item" onclick="invertColors()">Inverser <span class="shortcut">Ctrl+I</span></div>
      <div class="dropdown-sep"></div>
      <div class="dropdown-item" onclick="showResizeModal()">Taille de l'image... <span class="shortcut">Alt+Ctrl+I</span></div>
      <div class="dropdown-item" onclick="showCanvasResizeModal()">Taille de la zone de travail...</div>
      <div class="dropdown-item" onclick="rotateCanvas('90cw')">Rotation 90° horaire</div>
      <div class="dropdown-item" onclick="rotateCanvas('90ccw')">Rotation 90° anti-horaire</div>
      <div class="dropdown-item" onclick="rotateCanvas('180')">Rotation 180°</div>
      <div class="dropdown-item" onclick="flipHorizontal()">Rotation horizontale</div>
      <div class="dropdown-item" onclick="flipVertical()">Rotation verticale</div>
    </div>
  </div>

  <div class="menu-item">Filtre
    <div class="dropdown">
      <div class="dropdown-item" onclick="applyFilter('blur')">Flou gaussien...</div>
      <div class="dropdown-item" onclick="applyFilter('sharpen')">Accentuation</div>
      <div class="dropdown-item" onclick="applyFilter('noise')">Ajout de bruit...</div>
      <div class="dropdown-sep"></div>
      <div class="dropdown-item" onclick="applyFilter('emboss')">Emboss</div>
      <div class="dropdown-item" onclick="applyFilter('edge')">Détection des contours</div>
      <div class="dropdown-item" onclick="applyFilter('sepia')">Sépia</div>
      <div class="dropdown-item" onclick="applyFilter('grayscale')">Niveaux de gris</div>
      <div class="dropdown-item" onclick="applyFilter('vintage')">Vintage</div>
      <div class="dropdown-item" onclick="applyFilter('vignette')">Vignette</div>
      <div class="dropdown-item" onclick="applyFilter('pixelate')">Pixelisation</div>
      <div class="dropdown-item" onclick="applyFilter('cartoon')">Effet cartoon</div>
    </div>
  </div>

  <div class="menu-item">Calques
    <div class="dropdown">
