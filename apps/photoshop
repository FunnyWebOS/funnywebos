function renderPickerSpectrum() {
  const canvas = document.getElementById('picker-spectrum');
  const c = canvas.getContext('2d');
  const w = canvas.width, h = canvas.height;
  // White to hue gradient (horizontal)
  const hGrad = c.createLinearGradient(0, 0, w, 0);
  hGrad.addColorStop(0, 'white');
  hGrad.addColorStop(1, `hsl(${pickerHue}, 100%, 50%)`);
  c.fillStyle = hGrad; c.fillRect(0, 0, w, h);
  // Transparent to black gradient (vertical)
  const vGrad = c.createLinearGradient(0, 0, 0, h);
  vGrad.addColorStop(0, 'transparent');
  vGrad.addColorStop(1, 'black');
  c.fillStyle = vGrad; c.fillRect(0, 0, w, h);

  canvas.onmousedown = (e) => {
    const pickFromSpectrum = (ev) => {
      const rect = canvas.getBoundingClientRect();
      const x = Math.max(0, Math.min(w - 1, (ev.clientX - rect.left) * (w / rect.width)));
      const y = Math.max(0, Math.min(h - 1, (ev.clientY - rect.top) * (h / rect.height)));
      const pixel = c.getImageData(x, y, 1, 1).data;
      setPickerColorDirect(pixel[0], pixel[1], pixel[2]);
    };
    pickFromSpectrum(e);
    const move = (ev) => pickFromSpectrum(ev);
    const up = () => { window.removeEventListener('mousemove', move); window.removeEventListener('mouseup', up); };
    window.addEventListener('mousemove', move);
    window.addEventListener('mouseup', up);
  };
}

function renderPickerHueStrip() {
  const canvas = document.getElementById('picker-hue-strip');
  const c = canvas.getContext('2d');
  const w = canvas.width, h = canvas.height;
  const grad = c.createLinearGradient(0, 0, 0, h);
  for (let i = 0; i <= 360; i += 30) {
    grad.addColorStop(i / 360, `hsl(${i}, 100%, 50%)`);
  }
  c.fillStyle = grad; c.fillRect(0, 0, w, h);

  canvas.onmousedown = (e) => {
    const pickHue = (ev) => {
      const rect = canvas.getBoundingClientRect();
      const y = Math.max(0, Math.min(h - 1, (ev.clientY - rect.top) * (h / rect.height)));
      pickerHue = Math.round((y / h) * 360);
      renderPickerSpectrum();
      const rgb = hslToRgb(pickerHue / 360, pickerS, pickerV);
      setPickerColorDirect(rgb[0], rgb[1], rgb[2]);
    };
    pickHue(e);
    const move = (ev) => pickHue(ev);
    const up = () => { window.removeEventListener('mousemove', move); window.removeEventListener('mouseup', up); };
    window.addEventListener('mousemove', move);
    window.addEventListener('mouseup', up);
  };
}

