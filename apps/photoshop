function addNewLayer() {
  const name = `Calque ${layers.length}`;
  const offscreen = document.createElement('canvas');
  offscreen.width = mainCanvas.width; offscreen.height = mainCanvas.height;
  layers.unshift({ name, canvas: offscreen, visible: true, locked: false, opacity: 1.0, blend: 'source-over' });
  activeLayerIndex = 0;
  updateLayersPanel();
  saveHistory('Nouveau calque');
}

function duplicateLayer() {
  const src = layers[activeLayerIndex];
  if (!src) return;
  const offscreen = document.createElement('canvas');
  offscreen.width = src.canvas.width; offscreen.height = src.canvas.height;
  offscreen.getContext('2d').drawImage(src.canvas, 0, 0);
  const newLayer = { ...src, name: src.name + ' copie', canvas: offscreen };
  layers.splice(activeLayerIndex, 0, newLayer);
  updateLayersPanel();
  saveHistory('Dupliquer calque');
}

function deleteActiveLayer() {
  if (layers.length <= 1) return alert('Impossible de supprimer le seul calque.');
  layers.splice(activeLayerIndex, 1);
  activeLayerIndex = Math.min(activeLayerIndex, layers.length - 1);
  renderAllLayers();
  updateLayersPanel();
  saveHistory('Supprimer calque');
}

function moveLayerUp() {
  if (activeLayerIndex <= 0) return;
  [layers[activeLayerIndex], layers[activeLayerIndex - 1]] = [layers[activeLayerIndex - 1], layers[activeLayerIndex]];
  activeLayerIndex--;
  renderAllLayers();
  updateLayersPanel();
}

function moveLayerDown() {
  if (activeLayerIndex >= layers.length - 1) return;
  [layers[activeLayerIndex], layers[activeLayerIndex + 1]] = [layers[activeLayerIndex + 1], layers[activeLayerIndex]];
  activeLayerIndex++;
  renderAllLayers();
  updateLayersPanel();
}

function flattenImage() {
  const offscreen = document.createElement('canvas');
  offscreen.width = mainCanvas.width; offscreen.height = mainCanvas.height;
  const oc = offscreen.getContext('2d');
  for (let i = layers.length - 1; i >= 0; i--) {
    if (!layers[i].visible) continue;
    oc.globalAlpha = layers[i].opacity;
    oc.globalCompositeOperation = layers[i].blend || 'source-over';
    oc.drawImage(layers[i].canvas, 0, 0);
  }
  oc.globalAlpha = 1; oc.globalCompositeOperation = 'source-over';
  layers = [{ name: 'Arrière-plan', canvas: offscreen, visible: true, locked: false, opacity: 1.0, blend: 'source-over' }];
  activeLayerIndex = 0;
  renderAllLayers();
  updateLayersPanel();
  saveHistory('Aplatir image');
}

function mergeLayers() { flattenImage(); }

function setLayerBlend(val) {
  const blendMap = {
    'Normal': 'source-over', 'Multiplier': 'multiply', 'Écran': 'screen',
    'Superposition': 'overlay', 'Lumière douce': 'soft-light'
  };
  if (layers[activeLayerIndex]) {
    layers[activeLayerIndex].blend = blendMap[val] || 'source-over';
    renderAllLayers();
  }
}

function setLayerOpacity(val) {
  if (layers[activeLayerIndex]) {
    layers[activeLayerIndex].opacity = Math.max(0, Math.min(100, parseInt(val))) / 100;
    renderAllLayers();
  }
}

function updateLayersPanel() {
  const list = document.getElementById('layers-list');
  list.innerHTML = '';
  layers.forEach((layer, idx) => {
    const item = document.createElement('div');
    item.className = 'layer-item' + (idx === activeLayerIndex ? ' active' : '');
    item.innerHTML = `
      <div class="layer-vis" onclick="toggleLayerVis(${idx})">${layer.visible ? '👁' : '⬛'}</div>
      <canvas class="layer-thumb" id="thumb-${idx}" width="32" height="24"></canvas>
      <div class="layer-name" ondblclick="renameLayer(${idx})">${layer.name}</div>
      <div class="layer-lock" onclick="toggleLayerLock(${idx})">${layer.locked ? '🔒' : '🔓'}</div>
    `;
    item.addEventListener('click', (e) => {
      if (!e.target.classList.contains('layer-vis') && !e.target.classList.contains('layer-lock')) {
        activeLayerIndex = idx;
        updateLayersPanel();
      }
    });
    list.appendChild(item);
    // Draw thumb
    setTimeout(() => {
      const thumb = document.getElementById('thumb-' + idx);
      if (thumb) thumb.getContext('2d').drawImage(layer.canvas, 0, 0, 32, 24);
    }, 10);
  });
}

function updateLayerThumbs() {
  layers.forEach((layer, idx) => {
    const thumb = document.getElementById('thumb-' + idx);
    if (thumb) thumb.getContext('2d').drawImage(layer.canvas, 0, 0, 32, 24);
  });
}

function toggleLayerVis(idx) {
  layers[idx].visible = !layers[idx].visible;
  updateLayersPanel();
  renderAllLayers();
}

function toggleLayerLock(idx) {
  layers[idx].locked = !layers[idx].locked;
  updateLayersPanel();
}

function renameLayer(idx) {
  const name = prompt('Nom du calque:', layers[idx].name);
  if (name) { layers[idx].name = name; updateLayersPanel(); }
}

// ===================================================================
// HISTORY
// ===================================================================
function saveHistory(action) {
  // Trim future history
  if (historyIndex < history.length - 1) {
    history = history.slice(0, historyIndex + 1);
  }
  // Save composite snapshot
  const snapshot = {
    action,
    data: layers.map(l => {
      const c = l.canvas;
      const offscreen = document.createElement('canvas');
      offscreen.width = c.width; offscreen.height = c.height;
      offscreen.getContext('2d').drawImage(c, 0, 0);
      return { ...l, canvas: offscreen };
    }),
    width: mainCanvas.width,
    height: mainCanvas.height,
    activeLayer: activeLayerIndex
  };
  history.push(snapshot);
  if (history.length > MAX_HISTORY) history.shift();
  historyIndex = history.length - 1;
  updateHistoryPanel();
  updateLayerThumbs();
}

function doUndo() {
  if (historyIndex <= 0) return;
  historyIndex--;
  restoreHistory(historyIndex);
}

function doRedo() {
  if (historyIndex >= history.length - 1) return;
  historyIndex++;
  restoreHistory(historyIndex);
}

function restoreHistory(idx) {
  const snap = history[idx];
  if (!snap) return;
  mainCanvas.width = snap.width; mainCanvas.height = snap.height;
  layers = snap.data.map(l => {
    const offscreen = document.createElement('canvas');
    offscreen.width = l.canvas.width; offscreen.height = l.canvas.height;
    offscreen.getContext('2d').drawImage(l.canvas, 0, 0);
    return { ...l, canvas: offscreen };
  });
  activeLayerIndex = snap.activeLayer;
  renderAllLayers();
  updateLayersPanel();
  updateHistoryPanel();
  updateDocInfo();
}

function updateHistoryPanel() {
  const list = document.getElementById('history-list');
  list.innerHTML = '';
  const icons = { 'Pinceau': '🖌️', 'Gomme': '🩹', 'Remplissage': '🪣', 'Texte': 'T', 'Forme': '⬜', 'Dégradé': '🌈', 'Recadrage': '✂️', 'Nouveau calque': '＋', 'Aplatir image': '⬛', 'Filtre': '✨', 'Réglage': '⚙️', 'Nouveau document': '📄' };
  history.forEach((h, i) => {
    const item = document.createElement('div');
    item.className = 'history-item' + (i === historyIndex ? ' current' : '');
    const icon = icons[h.action] || '⚙️';
    item.innerHTML = `<span class="history-icon">${icon}</span><span>${h.action}</span>`;
    item.onclick = () => { historyIndex = i; restoreHistory(i); };
    list.appendChild(item);
  });
  list.scrollTop = list.scrollHeight;
}

