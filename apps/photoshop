function rotateCanvas(dir) {
  const w = mainCanvas.width, h = mainCanvas.height;
  let nw, nh, angle;
  if (dir === '90cw') { nw = h; nh = w; angle = Math.PI / 2; }
  else if (dir === '90ccw') { nw = h; nh = w; angle = -Math.PI / 2; }
  else { nw = w; nh = h; angle = Math.PI; }

  layers.forEach(layer => {
    const temp = document.createElement('canvas');
    temp.width = nw; temp.height = nh;
    const tc = temp.getContext('2d');
    tc.translate(nw / 2, nh / 2);
    tc.rotate(angle);
    tc.drawImage(layer.canvas, -w/2, -h/2);
    layer.canvas.width = nw; layer.canvas.height = nh;
    layer.canvas.getContext('2d').drawImage(temp, 0, 0);
  });
  mainCanvas.width = nw; mainCanvas.height = nh;
  renderAllLayers(); saveHistory('Rotation'); updateDocInfo(); updateLayerThumbs();
}

function flipHorizontal() {
  layers.forEach(layer => {
    const temp = document.createElement('canvas');
    temp.width = layer.canvas.width; temp.height = layer.canvas.height;
    const tc = temp.getContext('2d');
    tc.translate(temp.width, 0); tc.scale(-1, 1);
    tc.drawImage(layer.canvas, 0, 0);
    layer.canvas.getContext('2d').clearRect(0,0,layer.canvas.width,layer.canvas.height);
    layer.canvas.getContext('2d').drawImage(temp, 0, 0);
  });
  renderAllLayers(); saveHistory('Miroir H'); updateLayerThumbs();
}

function flipVertical() {
  layers.forEach(layer => {
    const temp = document.createElement('canvas');
    temp.width = layer.canvas.width; temp.height = layer.canvas.height;
    const tc = temp.getContext('2d');
    tc.translate(0, temp.height); tc.scale(1, -1);
    tc.drawImage(layer.canvas, 0, 0);
    layer.canvas.getContext('2d').clearRect(0,0,layer.canvas.width,layer.canvas.height);
    layer.canvas.getContext('2d').drawImage(temp, 0, 0);
  });
  renderAllLayers(); saveHistory('Miroir V'); updateLayerThumbs();
}

