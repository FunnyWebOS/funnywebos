function doCut() {
  if (!selectionActive || !selection) return;
  const lctx = getActiveLayerCtx();
  // Copy
  const imgData = lctx.getImageData(selection.x, selection.y, selection.w, selection.h);
  window._clipboard = imgData;
  // Clear
  lctx.clearRect(selection.x, selection.y, selection.w, selection.h);
  renderAllLayers(); saveHistory('Couper');
}

function doCopy() {
  if (!selectionActive || !selection) {
    window._clipboard = getActiveLayerCtx().getImageData(0, 0, mainCanvas.width, mainCanvas.height);
    return;
  }
  window._clipboard = getActiveLayerCtx().getImageData(selection.x, selection.y, selection.w, selection.h);
}

function doPaste() {
  if (!window._clipboard) return;
  addNewLayer();
  getActiveLayerCtx().putImageData(window._clipboard, 0, 0);
  renderAllLayers(); saveHistory('Coller');
  updateLayersPanel();
}

function clearArea() {
  const lctx = getActiveLayerCtx();
  if (selectionActive && selection) {
    lctx.clearRect(selection.x, selection.y, selection.w, selection.h);
  } else {
    lctx.clearRect(0, 0, mainCanvas.width, mainCanvas.height);
  }
  renderAllLayers(); saveHistory('Effacer');
}

function fillFG() {
  const lctx = getActiveLayerCtx();
  lctx.save(); lctx.fillStyle = fgColor;
  if (selectionActive && selection) lctx.fillRect(selection.x, selection.y, selection.w, selection.h);
  else lctx.fillRect(0, 0, mainCanvas.width, mainCanvas.height);
  lctx.restore(); renderAllLayers(); saveHistory('Remplissage FG');
}

function fillBG() {
  const lctx = getActiveLayerCtx();
  lctx.save(); lctx.fillStyle = bgColor;
  if (selectionActive && selection) lctx.fillRect(selection.x, selection.y, selection.w, selection.h);
  else lctx.fillRect(0, 0, mainCanvas.width, mainCanvas.height);
  lctx.restore(); renderAllLayers(); saveHistory('Remplissage BG');
}

