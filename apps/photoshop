function applyAdjustment() {
  const lctx = getActiveLayerCtx();
  const imgData = lctx.getImageData(0, 0, mainCanvas.width, mainCanvas.height);
  const d = imgData.data;

  if (currentAdj === 'brightness' || currentAdj === 'contrast') {
    const brightness = parseInt(document.getElementById('adj-brightness').value);
    const contrast = parseInt(document.getElementById('adj-contrast').value);
    const factor = (259 * (contrast + 255)) / (255 * (259 - contrast));
    for (let i = 0; i < d.length; i += 4) {
      d[i] = Math.max(0, Math.min(255, factor * (d[i] - 128) + 128 + brightness));
      d[i+1] = Math.max(0, Math.min(255, factor * (d[i+1] - 128) + 128 + brightness));
      d[i+2] = Math.max(0, Math.min(255, factor * (d[i+2] - 128) + 128 + brightness));
    }
  } else if (currentAdj === 'hsl') {
    const hShift = parseInt(document.getElementById('adj-hue').value);
    const sShift = parseInt(document.getElementById('adj-sat').value) / 100;
    const lShift = parseInt(document.getElementById('adj-light').value) / 100;
    for (let i = 0; i < d.length; i += 4) {
      const hsl = rgbToHsl(d[i], d[i+1], d[i+2]);
      hsl[0] = (hsl[0] * 360 + hShift) / 360 % 1;
      if (hsl[0] < 0) hsl[0] += 1;
      hsl[1] = Math.max(0, Math.min(1, hsl[1] + sShift));
      hsl[2] = Math.max(0, Math.min(1, hsl[2] + lShift));
      const rgb = hslToRgb(hsl[0], hsl[1], hsl[2]);
      d[i] = rgb[0]; d[i+1] = rgb[1]; d[i+2] = rgb[2];
    }
  } else if (currentAdj === 'levels') {
    const inMin = parseInt(document.getElementById('adj-in-min').value);
    const inMax = parseInt(document.getElementById('adj-in-max').value);
    const gamma = parseInt(document.getElementById('adj-gamma').value) / 100;
    const outMin = parseInt(document.getElementById('adj-out-min').value);
    const outMax = parseInt(document.getElementById('adj-out-max').value);
    for (let i = 0; i < d.length; i += 4) {
      for (let c = 0; c < 3; c++) {
        let v = d[i + c];
        v = (v - inMin) / (inMax - inMin);
        v = Math.max(0, Math.min(1, v));
        v = Math.pow(v, 1 / gamma);
        v = outMin + v * (outMax - outMin);
        d[i + c] = Math.max(0, Math.min(255, v));
      }
    }
  } else if (currentAdj === 'colorbalance') {
    const cr = parseInt(document.getElementById('adj-cr').value);
    const cg = parseInt(document.getElementById('adj-cg').value);
    const cb = parseInt(document.getElementById('adj-cb').value);
    for (let i = 0; i < d.length; i += 4) {
      d[i] = Math.max(0, Math.min(255, d[i] + cr));
      d[i+1] = Math.max(0, Math.min(255, d[i+1] + cg));
      d[i+2] = Math.max(0, Math.min(255, d[i+2] + cb));
    }
  }

  lctx.putImageData(imgData, 0, 0);
  renderAllLayers();
  saveHistory('Réglage: ' + currentAdj);
  closeModal('modal-adj');
  updateLayerThumbs();
}

function desaturate() {
  const lctx = getActiveLayerCtx();
  const imgData = lctx.getImageData(0, 0, mainCanvas.width, mainCanvas.height);
  const d = imgData.data;
  for (let i = 0; i < d.length; i += 4) {
    const gray = 0.299 * d[i] + 0.587 * d[i+1] + 0.114 * d[i+2];
    d[i] = d[i+1] = d[i+2] = gray;
  }
  lctx.putImageData(imgData, 0, 0);
  renderAllLayers(); saveHistory('Désaturation');
  updateLayerThumbs();
}

function invertColors() {
  const lctx = getActiveLayerCtx();
  const imgData = lctx.getImageData(0, 0, mainCanvas.width, mainCanvas.height);
  const d = imgData.data;
  for (let i = 0; i < d.length; i += 4) {
    d[i] = 255 - d[i]; d[i+1] = 255 - d[i+1]; d[i+2] = 255 - d[i+2];
  }
  lctx.putImageData(imgData, 0, 0);
  renderAllLayers(); saveHistory('Inverser');
  updateLayerThumbs();
}

