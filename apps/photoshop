<script>
// ===================================================================
// GLOBAL STATE
// ===================================================================
let currentTool = 'brush';
let zoom = 100;
let fgColor = '#000000';
let bgColor = '#ffffff';
let brushSize = 20;
let brushOpacity = 1.0;
let blendMode = 'source-over';
let showGrid = false;
let showRulers = false;

let layers = [];
let activeLayerIndex = 0;

let history = [];
let historyIndex = -1;
const MAX_HISTORY = 30;

let isDrawing = false;
let lastX = 0, lastY = 0;
let startX = 0, startY = 0;

// Selection
let selection = null;
let selectionActive = false;

// Lasso
let lassoPoints = [];
let lassoActive = false;

// Crop
let cropRect = null;
let isCropping = false;

// Gradient
let gradientStart = null;
let gradientDrawing = false;

// Move
let moveStartX = 0, moveStartY = 0;
let moveLayerData = null;

// Stamp
let stampSource = null;
let stampSampled = false;

// Smudge
let smudgeData = null;

// Color picker
let colorPickerTarget = 'fg';
let pickerHue = 0;
let pickerS = 0, pickerV = 0;

// Current adjustment type
let currentAdj = '';
let currentFilter = '';

// Text tool
let textX = 0, textY = 0;

// ===================================================================
// CANVAS SETUP
// ===================================================================
const mainCanvas = document.getElementById('main-canvas');
const ctx = mainCanvas.getContext('2d');

function initApp() {
  // Create initial layer
  layers = [];
  addLayerInternal('Arrière-plan', true);
  fillLayerWhite(0);
  renderAllLayers();
  updateLayersPanel();
  saveHistory('Nouveau document');
  drawColorWheel();
  renderPickerSpectrum();
  renderPickerHueStrip();
}

function addLayerInternal(name, isBg) {
  const offscreen = document.createElement('canvas');
  offscreen.width = mainCanvas.width;
  offscreen.height = mainCanvas.height;
  layers.unshift({ name, canvas: offscreen, visible: true, locked: false, opacity: 1.0, blend: 'source-over', isBg: !!isBg });
  activeLayerIndex = 0;
}

function fillLayerWhite(idx) {
  const lctx = layers[idx].canvas.getContext('2d');
  lctx.fillStyle = '#ffffff';
  lctx.fillRect(0, 0, layers[idx].canvas.width, layers[idx].canvas.height);
}

function getActiveLayerCtx() {
  if (!layers[activeLayerIndex]) return null;
  return layers[activeLayerIndex].canvas.getContext('2d');
}

function renderAllLayers() {
  ctx.clearRect(0, 0, mainCanvas.width, mainCanvas.height);
  // Draw checkered bg for transparency
  drawCheckerboard();
  for (let i = layers.length - 1; i >= 0; i--) {
    const l = layers[i];
    if (!l.visible) continue;
    ctx.globalAlpha = l.opacity;
    ctx.globalCompositeOperation = l.blend || 'source-over';
    ctx.drawImage(l.canvas, 0, 0);
  }
  ctx.globalAlpha = 1;
  ctx.globalCompositeOperation = 'source-over';
  if (showGrid) drawGrid();
}

function drawCheckerboard() {
  const size = 10;
  for (let y = 0; y < mainCanvas.height; y += size) {
    for (let x = 0; x < mainCanvas.width; x += size) {
      ctx.fillStyle = ((x / size + y / size) % 2 === 0) ? '#cccccc' : '#ffffff';
      ctx.fillRect(x, y, size, size);
    }
  }
}

function drawGrid() {
  ctx.save();
  ctx.strokeStyle = 'rgba(74,144,217,0.3)';
  ctx.lineWidth = 0.5;
  for (let x = 0; x <= mainCanvas.width; x += 50) {
    ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, mainCanvas.height); ctx.stroke();
  }
  for (let y = 0; y <= mainCanvas.height; y += 50) {
    ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(mainCanvas.width, y); ctx.stroke();
  }
  ctx.restore();
}

// ===================================================================
// TOOLS
// ===================================================================
function setTool(tool) {
  currentTool = tool;
  document.querySelectorAll('.tool-btn').forEach(b => b.classList.remove('active'));
  const btn = document.getElementById('tool-' + tool);
  if (btn) btn.classList.add('active');

  const names = {
    'brush': 'Pinceau', 'pencil': 'Crayon', 'eraser': 'Gomme',
    'eyedropper': 'Pipette', 'rect-select': 'Sélection rect.',
    'ellipse-select': 'Sélection elliptique', 'lasso': 'Lasso',
    'move': 'Déplacement', 'crop': 'Recadrage', 'fill': 'Remplissage',
    'gradient': 'Dégradé', 'text': 'Texte', 'shape-rect': 'Rectangle',
    'shape-ellipse': 'Ellipse', 'shape-line': 'Ligne',
    'blur': 'Flou', 'sharpen': 'Netteté', 'dodge': 'Densité -',
    'burn': 'Densité +', 'smudge': 'Doigt', 'stamp': 'Tampon',
    'zoom': 'Zoom', 'hand': 'Main'
  };
  document.getElementById('tool-name').textContent = names[tool] || tool;

  // Cursor
  const cursors = {
    'move': 'move', 'hand': 'grab', 'zoom': 'zoom-in',
    'eyedropper': 'crosshair', 'text': 'text', 'crop': 'crosshair'
  };
  mainCanvas.style.cursor = cursors[tool] || 'crosshair';
}

// ===================================================================
// CANVAS EVENTS
// ===================================================================
mainCanvas.addEventListener('mousedown', onMouseDown);
mainCanvas.addEventListener('mousemove', onMouseMove);
mainCanvas.addEventListener('mouseup', onMouseUp);
mainCanvas.addEventListener('mouseleave', () => { if (isDrawing) onMouseUp(); });
mainCanvas.addEventListener('wheel', onWheel);
mainCanvas.addEventListener('contextmenu', e => e.preventDefault());
mainCanvas.addEventListener('dblclick', onDblClick);

function getCanvasPos(e) {
  const rect = mainCanvas.getBoundingClientRect();
  const scaleX = mainCanvas.width / rect.width;
  const scaleY = mainCanvas.height / rect.height;
  return {
    x: Math.round((e.clientX - rect.left) * scaleX),
    y: Math.round((e.clientY - rect.top) * scaleY)
  };
}

function onMouseDown(e) {
  const pos = getCanvasPos(e);
  isDrawing = true;
  lastX = pos.x; lastY = pos.y;
  startX = pos.x; startY = pos.y;

  const lctx = getActiveLayerCtx();
  if (!lctx) return;

  if (currentTool === 'brush' || currentTool === 'pencil') {
    lctx.save();
    setupBrushCtx(lctx);
    lctx.beginPath();
    lctx.arc(pos.x, pos.y, brushSize / 2, 0, Math.PI * 2);
    lctx.fill();
    lctx.restore();
    renderAllLayers();
  } else if (currentTool === 'eraser') {
    lctx.save();
    lctx.globalCompositeOperation = 'destination-out';
    lctx.beginPath();
    lctx.arc(pos.x, pos.y, brushSize / 2, 0, Math.PI * 2);
    lctx.fill();
    lctx.restore();
    renderAllLayers();
  } else if (currentTool === 'eyedropper') {
    pickColor(pos.x, pos.y);
  } else if (currentTool === 'fill') {
    floodFill(lctx, pos.x, pos.y, hexToRgba(fgColor));
    renderAllLayers();
    saveHistory('Remplissage');
  } else if (currentTool === 'stamp') {
    if (e.altKey) {
      stampSource = { x: pos.x, y: pos.y, imageData: lctx.getImageData(0, 0, mainCanvas.width, mainCanvas.height) };
      stampSampled = true;
    }
  } else if (currentTool === 'move') {
    moveStartX = pos.x; moveStartY = pos.y;
    moveLayerData = lctx.getImageData(0, 0, mainCanvas.width, mainCanvas.height);
  } else if (currentTool === 'lasso') {
    lassoPoints = [pos];
    lassoActive = true;
  } else if (currentTool === 'zoom') {
    if (e.shiftKey) setZoom(zoom - 10);
    else setZoom(zoom + 10);
  }
}

function onMouseMove(e) {
  const pos = getCanvasPos(e);
  updateStatusBar(pos.x, pos.y);

  if (!isDrawing) return;
  const lctx = getActiveLayerCtx();
  if (!lctx) return;

  if (currentTool === 'brush' || currentTool === 'pencil') {
    lctx.save();
    setupBrushCtx(lctx);
    lctx.beginPath();
    lctx.moveTo(lastX, lastY);
    lctx.lineTo(pos.x, pos.y);
    lctx.lineWidth = brushSize;
    lctx.lineCap = 'round';
    lctx.lineJoin = 'round';
    lctx.stroke();
    lctx.restore();
    renderAllLayers();
  } else if (currentTool === 'eraser') {
    lctx.save();
    lctx.globalCompositeOperation = 'destination-out';
    lctx.beginPath();
    lctx.moveTo(lastX, lastY);
    lctx.lineTo(pos.x, pos.y);
    lctx.lineWidth = brushSize;
    lctx.lineCap = 'round';
    lctx.stroke();
    lctx.restore();
    renderAllLayers();
  } else if (currentTool === 'blur') {
    applyBrushFilter(lctx, pos.x, pos.y, 'blur');
    renderAllLayers();
  } else if (currentTool === 'sharpen') {
    applyBrushFilter(lctx, pos.x, pos.y, 'sharpen');
    renderAllLayers();
  } else if (currentTool === 'dodge') {
    applyBrushFilter(lctx, pos.x, pos.y, 'dodge');
    renderAllLayers();
  } else if (currentTool === 'burn') {
    applyBrushFilter(lctx, pos.x, pos.y, 'burn');
    renderAllLayers();
  } else if (currentTool === 'smudge') {
    applySmudge(lctx, pos.x, pos.y);
    renderAllLayers();
  } else if (currentTool === 'stamp' && stampSampled) {
    const dx = pos.x - stampSource.x;
    const dy = pos.y - stampSource.y;
    lctx.save();
    setupBrushCtx(lctx);
    const r = brushSize / 2;
    // Draw from source
    const tempCanvas = document.createElement('canvas');
    tempCanvas.width = mainCanvas.width; tempCanvas.height = mainCanvas.height;
    const tc = tempCanvas.getContext('2d');
    tc.putImageData(stampSource.imageData, 0, 0);
    lctx.beginPath();
    lctx.arc(pos.x, pos.y, r, 0, Math.PI * 2);
    lctx.clip();
    lctx.drawImage(tempCanvas, dx, dy);
    lctx.restore();
    renderAllLayers();
  } else if (currentTool === 'rect-select' || currentTool === 'ellipse-select') {
    showSelectionPreview(startX, startY, pos.x, pos.y);
  } else if (currentTool === 'lasso') {
    lassoPoints.push(pos);
    drawLassoPreview();
  } else if (currentTool === 'shape-rect' || currentTool === 'shape-ellipse' || currentTool === 'shape-line') {
    renderAllLayers();
    drawShapePreview(ctx, startX, startY, pos.x, pos.y);
  } else if (currentTool === 'gradient') {
    renderAllLayers();
    drawGradientPreview(ctx, startX, startY, pos.x, pos.y);
  } else if (currentTool === 'move') {
    const dx = pos.x - moveStartX;
    const dy = pos.y - moveStartY;
    lctx.clearRect(0, 0, mainCanvas.width, mainCanvas.height);
    lctx.putImageData(moveLayerData, dx, dy);
    renderAllLayers();
  } else if (currentTool === 'crop') {
    showSelectionPreview(startX, startY, pos.x, pos.y);
  }

  lastX = pos.x; lastY = pos.y;
}

function onMouseUp(e) {
  if (!isDrawing) return;
  isDrawing = false;
  const lctx = getActiveLayerCtx();
  const pos = e ? getCanvasPos(e) : { x: lastX, y: lastY };

  if (currentTool === 'brush' || currentTool === 'pencil') {
    saveHistory('Pinceau');
  } else if (currentTool === 'eraser') {
    saveHistory('Gomme');
  } else if (currentTool === 'rect-select') {
    setSelection(Math.min(startX, pos.x), Math.min(startY, pos.y),
      Math.abs(pos.x - startX), Math.abs(pos.y - startY), 'rect');
  } else if (currentTool === 'ellipse-select') {
    setSelection(Math.min(startX, pos.x), Math.min(startY, pos.y),
      Math.abs(pos.x - startX), Math.abs(pos.y - startY), 'ellipse');
  } else if (currentTool === 'lasso' && lassoPoints.length > 2) {
    finalizeLasso();
  } else if (currentTool === 'shape-rect' || currentTool === 'shape-ellipse' || currentTool === 'shape-line') {
    drawShapeFinal(lctx, startX, startY, pos.x, pos.y);
    renderAllLayers();
    saveHistory('Forme');
  } else if (currentTool === 'gradient') {
    applyGradient(lctx, startX, startY, pos.x, pos.y);
    renderAllLayers();
    saveHistory('Dégradé');
  } else if (currentTool === 'crop') {
    cropRect = { x: Math.min(startX, pos.x), y: Math.min(startY, pos.y), w: Math.abs(pos.x - startX), h: Math.abs(pos.y - startY) };
    if (cropRect.w > 5 && cropRect.h > 5) doCrop();
  } else if (currentTool === 'move') {
    saveHistory('Déplacement');
  } else if (currentTool === 'dodge' || currentTool === 'burn' || currentTool === 'blur' || currentTool === 'sharpen' || currentTool === 'smudge' || currentTool === 'stamp') {
    saveHistory(currentTool);
  }
  updateLayerThumbs();
}

function onDblClick(e) {
  if (currentTool === 'text') {
    const pos = getCanvasPos(e);
    showTextInput(pos.x, pos.y);
  }
}

function onWheel(e) {
  e.preventDefault();
  if (e.ctrlKey || e.metaKey) {
    if (e.deltaY < 0) setZoom(zoom + 10);
    else setZoom(zoom - 10);
  }
}

// ===================================================================
// BRUSH HELPERS
// ===================================================================
function setupBrushCtx(lctx) {
  lctx.globalAlpha = brushOpacity;
  lctx.globalCompositeOperation = blendMode;
  lctx.fillStyle = fgColor;
  lctx.strokeStyle = fgColor;
  // Soft brush with radial gradient
  if (currentTool === 'brush') {
    const hardness = parseInt(document.getElementById('brush-hardness').value) / 100;
    // For fill ops we use a gradient
    const r = brushSize / 2;
    const grad = lctx.createRadialGradient(0, 0, r * hardness, 0, 0, r);
    const rgb = hexToRgb(fgColor);
    grad.addColorStop(0, `rgba(${rgb.r},${rgb.g},${rgb.b},${brushOpacity})`);
    grad.addColorStop(1, `rgba(${rgb.r},${rgb.g},${rgb.b},0)`);
    lctx.fillStyle = grad;
    lctx.strokeStyle = fgColor;
  }
}

function applyBrushFilter(lctx, x, y, type) {
  const r = brushSize;
  const x0 = Math.max(0, x - r), y0 = Math.max(0, y - r);
  const w = Math.min(r * 2, mainCanvas.width - x0);
  const h = Math.min(r * 2, mainCanvas.height - y0);
  if (w <= 0 || h <= 0) return;
  const imgData = lctx.getImageData(x0, y0, w, h);
  const d = imgData.data;
  for (let i = 0; i < d.length; i += 4) {
    const px = (i / 4) % w;
    const py = Math.floor(i / 4 / w);
    const dist = Math.sqrt((px - r) ** 2 + (py - r) ** 2);
    if (dist > r) continue;
    const strength = (1 - dist / r) * 0.3;
    if (type === 'blur') {
      // Simple average with neighbors
      const avg = (d[i] + d[i + 1] + d[i + 2]) / 3;
      d[i] = d[i] * (1 - strength) + avg * strength;
      d[i+1] = d[i+1] * (1 - strength) + avg * strength;
      d[i+2] = d[i+2] * (1 - strength) + avg * strength;
    } else if (type === 'dodge') {
      d[i] = Math.min(255, d[i] + 20 * strength);
      d[i+1] = Math.min(255, d[i+1] + 20 * strength);
      d[i+2] = Math.min(255, d[i+2] + 20 * strength);
    } else if (type === 'burn') {
      d[i] = Math.max(0, d[i] - 20 * strength);
      d[i+1] = Math.max(0, d[i+1] - 20 * strength);
      d[i+2] = Math.max(0, d[i+2] - 20 * strength);
    } else if (type === 'sharpen') {
      d[i] = Math.min(255, d[i] * (1 + strength));
      d[i+1] = Math.min(255, d[i+1] * (1 + strength));
      d[i+2] = Math.min(255, d[i+2] * (1 + strength));
    }
  }
  lctx.putImageData(imgData, x0, y0);
}

function applySmudge(lctx, x, y) {
  if (!smudgeData) {
    smudgeData = lctx.getImageData(x - brushSize, y - brushSize, brushSize * 2, brushSize * 2);
    return;
  }
  const r = brushSize / 2;
  const x0 = Math.max(0, x - r), y0 = Math.max(0, y - r);
  const w = Math.min(r * 2, mainCanvas.width - x0);
  const h = Math.min(r * 2, mainCanvas.height - y0);
  if (w <= 0 || h <= 0) return;
  const curr = lctx.getImageData(x0, y0, w, h);
  for (let i = 0; i < curr.data.length; i += 4) {
    curr.data[i] = curr.data[i] * 0.7 + (smudgeData.data[i] || 0) * 0.3;
    curr.data[i+1] = curr.data[i+1] * 0.7 + (smudgeData.data[i+1] || 0) * 0.3;
    curr.data[i+2] = curr.data[i+2] * 0.7 + (smudgeData.data[i+2] || 0) * 0.3;
  }
  lctx.putImageData(curr, x0, y0);
}

// ===================================================================
// SHAPES
// ===================================================================
function drawShapePreview(c, x1, y1, x2, y2) {
  c.save();
  c.strokeStyle = fgColor;
  c.fillStyle = fgColor;
  c.lineWidth = brushSize / 5 || 2;
  c.globalAlpha = 0.7;
  c.setLineDash([5, 3]);
  if (currentTool === 'shape-rect') {
    c.strokeRect(Math.min(x1,x2), Math.min(y1,y2), Math.abs(x2-x1), Math.abs(y2-y1));
  } else if (currentTool === 'shape-ellipse') {
    c.beginPath();
    c.ellipse((x1+x2)/2, (y1+y2)/2, Math.abs(x2-x1)/2, Math.abs(y2-y1)/2, 0, 0, Math.PI*2);
    c.stroke();
  } else if (currentTool === 'shape-line') {
    c.beginPath(); c.moveTo(x1,y1); c.lineTo(x2,y2); c.stroke();
  }
  c.restore();
}

function drawShapeFinal(lctx, x1, y1, x2, y2) {
  lctx.save();
  lctx.strokeStyle = fgColor;
  lctx.fillStyle = fgColor;
  lctx.lineWidth = Math.max(1, brushSize / 5);
  lctx.globalAlpha = brushOpacity;
  lctx.globalCompositeOperation = blendMode;
  lctx.setLineDash([]);
  if (currentTool === 'shape-rect') {
    lctx.fillRect(Math.min(x1,x2), Math.min(y1,y2), Math.abs(x2-x1), Math.abs(y2-y1));
    lctx.strokeRect(Math.min(x1,x2), Math.min(y1,y2), Math.abs(x2-x1), Math.abs(y2-y1));
  } else if (currentTool === 'shape-ellipse') {
    lctx.beginPath();
    lctx.ellipse((x1+x2)/2, (y1+y2)/2, Math.abs(x2-x1)/2, Math.abs(y2-y1)/2, 0, 0, Math.PI*2);
    lctx.fill(); lctx.stroke();
  } else if (currentTool === 'shape-line') {
    lctx.beginPath(); lctx.moveTo(x1,y1); lctx.lineTo(x2,y2); lctx.stroke();
  }
  lctx.restore();
}

// ===================================================================
// GRADIENT
// ===================================================================
function drawGradientPreview(c, x1, y1, x2, y2) {
  c.save();
  c.strokeStyle = 'rgba(255,255,255,0.8)';
  c.lineWidth = 2;
  c.setLineDash([4, 3]);
  c.beginPath(); c.moveTo(x1, y1); c.lineTo(x2, y2); c.stroke();
  c.restore();
}

function applyGradient(lctx, x1, y1, x2, y2) {
  if (x1 === x2 && y1 === y2) return;
  lctx.save();
  const grad = lctx.createLinearGradient(x1, y1, x2, y2);
  grad.addColorStop(0, fgColor);
  grad.addColorStop(1, bgColor);
  lctx.fillStyle = grad;
  lctx.globalAlpha = brushOpacity;
  lctx.globalCompositeOperation = blendMode;
  lctx.fillRect(0, 0, mainCanvas.width, mainCanvas.height);
  lctx.restore();
}

// ===================================================================
// SELECTION
// ===================================================================
function setSelection(x, y, w, h, type) {
  if (w < 2 || h < 2) { deselect(); return; }
  selection = { x, y, w, h, type };
  selectionActive = true;
  showSelectionOverlay(x, y, w, h);
}

function showSelectionPreview(x1, y1, x2, y2) {
  const x = Math.min(x1, x2), y = Math.min(y1, y2);
  const w = Math.abs(x2 - x1), h = Math.abs(y2 - y1);
  showSelectionOverlay(x, y, w, h);
}

function showSelectionOverlay(x, y, w, h) {
  const wrapper = document.getElementById('canvas-wrapper');
  const rect = mainCanvas.getBoundingClientRect();
  const canvasRect = mainCanvas.getBoundingClientRect();
  const scaleX = rect.width / mainCanvas.width;
  const scaleY = rect.height / mainCanvas.height;
  const el = document.getElementById('selection-overlay');
  el.style.display = 'block';
  el.style.left = (x * scaleX) + 'px';
  el.style.top = (y * scaleY) + 'px';
  el.style.width = (w * scaleX) + 'px';
  el.style.height = (h * scaleY) + 'px';
  el.style.borderRadius = (currentTool === 'ellipse-select') ? '50%' : '0';
}

function deselect() {
  selection = null;
  selectionActive = false;
  document.getElementById('selection-overlay').style.display = 'none';
  lassoPoints = [];
}

function selectAll() {
  setSelection(0, 0, mainCanvas.width, mainCanvas.height, 'rect');
  showSelectionOverlay(0, 0, mainCanvas.width, mainCanvas.height);
}

// ===================================================================
// LASSO
// ===================================================================
function drawLassoPreview() {
  renderAllLayers();
  ctx.save();
  ctx.strokeStyle = 'rgba(255,255,255,0.9)';
  ctx.lineWidth = 1;
  ctx.setLineDash([4, 3]);
  ctx.beginPath();
  if (lassoPoints.length > 0) {
    ctx.moveTo(lassoPoints[0].x, lassoPoints[0].y);
    lassoPoints.forEach(p => ctx.lineTo(p.x, p.y));
  }
  ctx.stroke();
  ctx.restore();
}

function finalizeLasso() {
  if (lassoPoints.length < 3) return;
  // Compute bounding box
  const xs = lassoPoints.map(p => p.x);
  const ys = lassoPoints.map(p => p.y);
  const minX = Math.min(...xs), maxX = Math.max(...xs);
  const minY = Math.min(...ys), maxY = Math.max(...ys);
  selection = { x: minX, y: minY, w: maxX - minX, h: maxY - minY, type: 'lasso', points: lassoPoints };
  selectionActive = true;
  showSelectionOverlay(minX, minY, maxX - minX, maxY - minY);
  lassoActive = false;
}

// ===================================================================
// FLOOD FILL
// ===================================================================
function floodFill(lctx, startX, startY, fillColor) {
  const imgData = lctx.getImageData(0, 0, mainCanvas.width, mainCanvas.height);
  const data = imgData.data;
  const w = mainCanvas.width, h = mainCanvas.height;

  const idx = (startY * w + startX) * 4;
  const targetR = data[idx], targetG = data[idx+1], targetB = data[idx+2], targetA = data[idx+3];

  if (targetR === fillColor.r && targetG === fillColor.g && targetB === fillColor.b && targetA === fillColor.a) return;

  const stack = [[startX, startY]];
  const tolerance = 30;

  function matchesTarget(i) {
    return Math.abs(data[i] - targetR) <= tolerance &&
           Math.abs(data[i+1] - targetG) <= tolerance &&
           Math.abs(data[i+2] - targetB) <= tolerance;
  }

  function setPixel(i) {
    data[i] = fillColor.r;
    data[i+1] = fillColor.g;
    data[i+2] = fillColor.b;
    data[i+3] = fillColor.a || 255;
  }

  const visited = new Uint8Array(w * h);

  while (stack.length > 0) {
    const [x, y] = stack.pop();
    if (x < 0 || x >= w || y < 0 || y >= h) continue;
    const i = (y * w + x) * 4;
    if (visited[y * w + x]) continue;
    if (!matchesTarget(i)) continue;
    visited[y * w + x] = 1;
    setPixel(i);
    stack.push([x+1, y], [x-1, y], [x, y+1], [x, y-1]);
  }
  lctx.putImageData(imgData, 0, 0);
}

// ===================================================================
// EYEDROPPER
// ===================================================================
function pickColor(x, y) {
  const pixel = ctx.getImageData(x, y, 1, 1).data;
  fgColor = `rgb(${pixel[0]},${pixel[1]},${pixel[2]})`;
  document.getElementById('fg-color').style.background = fgColor;
  updateColorPanel(pixel[0], pixel[1], pixel[2]);
}

// ===================================================================
// CROP
// ===================================================================
function doCrop() {
  if (!cropRect || cropRect.w < 5 || cropRect.h < 5) return;
  const { x, y, w, h } = cropRect;
  layers.forEach(layer => {
    const temp = document.createElement('canvas');
    temp.width = w; temp.height = h;
    const tc = temp.getContext('2d');
    tc.drawImage(layer.canvas, -x, -y);
    layer.canvas.width = w; layer.canvas.height = h;
    const lctx = layer.canvas.getContext('2d');
    lctx.drawImage(temp, 0, 0);
  });
  mainCanvas.width = w; mainCanvas.height = h;
  deselect();
  renderAllLayers();
  saveHistory('Recadrage');
  updateDocInfo();
  updateLayerThumbs();
}

// ===================================================================
// TEXT
// ===================================================================
function showTextInput(x, y) {
  textX = x; textY = y;
  const wrapper = document.getElementById('canvas-wrapper');
  const el = document.getElementById('text-overlay');
  const scaleX = mainCanvas.getBoundingClientRect().width / mainCanvas.width;
  const scaleY = mainCanvas.getBoundingClientRect().height / mainCanvas.height;
  el.style.display = 'block';
  el.style.left = (x * scaleX) + 'px';
  el.style.top = (y * scaleY) + 'px';
  const ta = document.getElementById('text-input');
  if (!ta) {
    const newTa = document.createElement('textarea');
    newTa.id = 'text-input';
    newTa.style.cssText = 'background:transparent;border:1px dashed rgba(74,144,217,0.8);color:transparent;caret-color:#4a90d9;outline:none;resize:none;min-width:100px;min-height:30px;font-size:20px;font-family:sans-serif;padding:4px;';
    el.appendChild(newTa);
    newTa.addEventListener('blur', commitText);
    el.appendChild(newTa);
  }
  document.getElementById('text-input').value = '';
  document.getElementById('text-input').focus();
}

document.getElementById('canvas-wrapper').appendChild(document.getElementById('text-overlay') || (() => {
  const d = document.createElement('div');
  d.id = 'text-overlay'; d.style.position = 'absolute'; d.style.display = 'none'; d.style.zIndex = '50';
  const ta = document.createElement('textarea');
  ta.id = 'text-input';
  ta.style.cssText = 'background:transparent;border:1px dashed rgba(74,144,217,0.8);color:transparent;caret-color:#4a90d9;outline:none;resize:none;min-width:100px;min-height:30px;font-size:20px;padding:4px;';
  ta.addEventListener('blur', commitText);
  d.appendChild(ta);
  return d;
})());

function commitText() {
  const ta = document.getElementById('text-input');
  if (!ta || !ta.value.trim()) {
    document.getElementById('text-overlay').style.display = 'none';
    return;
  }
  const lctx = getActiveLayerCtx();
  const fontSize = parseInt(document.getElementById('brush-size').value) || 20;
  lctx.save();
  lctx.font = `${fontSize}px sans-serif`;
  lctx.fillStyle = fgColor;
  lctx.globalAlpha = brushOpacity;
  // Draw multiline
  const lines = ta.value.split('\n');
  lines.forEach((line, i) => lctx.fillText(line, textX, textY + (i + 1) * (fontSize + 4)));
  lctx.restore();
  renderAllLayers();
  saveHistory('Texte');
  document.getElementById('text-overlay').style.display = 'none';
  ta.value = '';
  updateLayerThumbs();
}

// ===================================================================
// COLORS
// ===================================================================
function swapColors() {
